# MongoDB connection URI
MONGO_URI=mongodb+srv://username:password@cluster.example.mongodb.net/social-app

# API server port
PORT=5000

# JWT signing secret (REQUIRED - do NOT commit a real secret)
# Example: JWT_SECRET=your-very-long-random-secret
JWT_SECRET=

# Comma-separated allowed CORS origins
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Runtime environment
NODE_ENV=development

# Logger verbosity (error, warn, info, http, verbose, debug, silly)
LOG_LEVEL=info
